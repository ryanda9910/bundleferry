{
  "name": "bundleferry",
  "version": "0.3.1",
  "description": "Ferry a JS/TS project across bundlers — plan a tiered migration between any bundler pair (webpack, CRA, Rollup, Parcel, esbuild → Vite, Rspack, esbuild, tsup, Rolldown) without sinking the build.",
  "type": "module",
  "bin": {
    "bundleferry": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "skill",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vite",
    "webpack",
    "rspack",
    "esbuild",
    "rollup",
    "parcel",
    "tsup",
    "bundler",
    "migration",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanda9910/bundleferry"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
